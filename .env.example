# ──────────────────────────────────────────────────────────────────────────────
# JITTER — Environment Variables Reference
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (or set these as Cloudflare Worker secrets) before
# running the server. The Chrome extension does NOT use .env files; configure
# it by editing extension/config.js directly with the values below.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server (Cloudflare Workers — server/jitter-db-api/) ──────────────────────

# 256-bit secret used to sign and verify HMAC-SHA256 certificates.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JITTER_HMAC_SECRET=replace-with-your-256-bit-secret

# ── E2E Contract Test (e2e-vault-verify.mjs) ─────────────────────────────────

# Must match JITTER_HMAC_SECRET set on the server.
# JITTER_HMAC_SECRET=replace-with-your-256-bit-secret

# Base URL of your deployed signing API (no trailing slash).
VAULT_BASE=https://your-api-domain.com

# ── Extension Configuration (edit extension/config.js manually) ──────────────
#
# VAULT_API_BASE      — Base URL of your HMAC vault API        (e.g. https://your-api-domain.com)
# REGISTRY_SAVE_URL   — Full URL of the registry write endpoint (e.g. https://your-worker.workers.dev/save)
# PORTAL_VERIFY_BASE  — Verification portal origin             (e.g. https://verify.your-domain.com)
# SEAL_IMAGE_URL      — Public URL of the seal image            (e.g. https://your-domain.com/seal.png)
# SEAL_VERIFY_HOST    — Hostname only, for clipboard heuristics (e.g. verify.your-domain.com)
# SEAL_IMG_MARKER     — URL substring for seal detection        (e.g. your-domain.com/seal.png)
#
# After setting these values, also update host_permissions and connect-src in
# extension/manifest.json to match your actual domains.
